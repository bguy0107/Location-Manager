generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Franchise {
  id        String          @id @default(uuid())
  name      String
  status    FranchiseStatus @default(ACTIVE)
  logoUrl   String?
  ownerId   String
  owner     User            @relation("FranchiseOwner", fields: [ownerId], references: [id])
  managers  User[]          @relation("FranchiseManagers")
  locations Location[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("franchises")
}

model User {
  id                        String                      @id @default(uuid())
  name                      String
  email                     String                      @unique
  password                  String
  role                      Role                        @default(USER)
  isActive                  Boolean                     @default(true)
  franchiseId               String?
  franchise                 Franchise?                  @relation("FranchiseManagers", fields: [franchiseId], references: [id])
  ownedFranchises           Franchise[]                 @relation("FranchiseOwner")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  locations                 UserLocation[]
  refreshTokens             RefreshToken[]
  surveillanceRequests      SurveillanceRequest[]
  surveillanceStatusChanges SurveillanceStatusHistory[]

  @@map("users")
}

model Location {
  id                   String                 @id @default(uuid())
  name                 String
  storeNumber          String
  address              String
  city                 String
  state                String
  zip                  String
  notes                String?
  franchiseId          String?
  franchise            Franchise?             @relation(fields: [franchiseId], references: [id])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  users                UserLocation[]
  surveillanceRequests SurveillanceRequest[]

  @@map("locations")
}

model UserLocation {
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, locationId])
  @@map("user_locations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model SurveillanceRequest {
  id              String          @id @default(uuid())
  locationId      String
  requestedById   String
  requestingParty RequestingParty
  status          RequestStatus   @default(PENDING)
  footageStartAt  DateTime
  footageEndAt    DateTime
  cameras         Int[]
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  location      Location                    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  requestedBy   User                        @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  statusHistory SurveillanceStatusHistory[]

  @@map("surveillance_requests")
}

model SurveillanceStatusHistory {
  id          String              @id @default(uuid())
  requestId   String
  changedById String
  fromStatus  RequestStatus
  toStatus    RequestStatus
  changedAt   DateTime            @default(now())
  request     SurveillanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedBy   User                @relation(fields: [changedById], references: [id])

  @@map("surveillance_status_history")
}

enum Role {
  ADMIN
  FRANCHISE_MANAGER
  MANAGER
  USER
  TECHNICIAN
}

enum FranchiseStatus {
  ACTIVE
  INACTIVE
}

enum RequestingParty {
  LAW_ENFORCEMENT
  INTERNAL
  INSURANCE
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  FULFILLED
  DENIED
}
